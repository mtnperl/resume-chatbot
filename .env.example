# Anthropic API Key (required)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vercel KV (required for rate limiting in production)
# Set these up at https://vercel.com/storage/kv
# Leave blank in local dev — rate limiting will be disabled (fail open)
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# PR 2: Admin dashboard (added in next PR)
# ADMIN_PASSWORD=your_admin_password_here
